# 私有配置（不提交到 git）
# 复制此文件为 .env 并填入真实值

# ===== Google Service Account =====
GOOGLE_APPLICATION_CREDENTIALS=./config/service-account.json

# ===== 环境变量覆盖（可选）=====
# 这些值会覆盖 config.yaml 中的对应配置
# 推荐使用环境变量存储敏感信息，避免明文写入配置文件

# Sheets 配置
# SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# 服务器配置
# SERVER_PORT=3000
# SERVER_API_KEY=your_secret_api_key_here

# LLM API Key
# LLM_API_KEY=your_openai_api_key

# Keyword API Key
# KEYWORD_API_KEY=your_aitdk_api_key

# 住宅代理
# PROXY_HOST=your_proxy_host
# PROXY_PORT=8080
# PROXY_USERNAME=your_proxy_user
# PROXY_PASSWORD=your_proxy_pass
